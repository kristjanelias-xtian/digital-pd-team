# Webhook Server — relay + trigger
PORT=3000

# Zeno Bot's Telegram token
ZENO_TELEGRAM_BOT_TOKEN=your-zeno-bot-token

# Zeno's DM chat ID (your chat with Zeno)
ZENO_DM_CHAT_ID=your-zeno-dm-chat-id

# Group ID (Zeno posts here himself when he decides to — not used by relay)
TELEGRAM_GROUP_ID=your-group-id

# Gateway tunnel ports (persistent SSH tunnels to bot sandboxes)
ZENO_GATEWAY_PORT=18801
LUX_GATEWAY_PORT=18802
TARO_GATEWAY_PORT=18803

# Gateway auth token (shared by all bots)
GATEWAY_TOKEN=your-gateway-token
