#!/usr/bin/env python3
"""pd-find-or-create-person — fuzzy search, create only if no close match."""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from lib.pd_client import PDClient, PDError  # noqa: E402
from lib.output import error, success  # noqa: E402
from lib.validators import fuzzy_match, safe_name  # noqa: E402


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--name", required=False)
    parser.add_argument("--email", default=None)
    parser.add_argument("--phone", default=None)
    parser.add_argument("--org-id", type=int, default=None)
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    try:
        safe_name(args.name or "", "--name")
    except ValueError as e:
        error(str(e), hint="--name is required (>=3 chars, not a placeholder)")

    pd = PDClient()
    try:
        # Prefer exact email match first
        if args.email:
            hits = pd.search_persons(args.email)
            for h in hits:
                emails = h.get("emails", []) or []
                if any(args.email.lower() == (e or "").lower() for e in emails):
                    success(f"person_id={h['id']} (found by email)", id=h["id"], mode="found")

        # Prefer exact phone match second
        if args.phone:
            hits = pd.search_persons(args.phone)
            for h in hits:
                phones = h.get("phones", []) or []
                if any(args.phone == p for p in phones):
                    success(f"person_id={h['id']} (found by phone)", id=h["id"], mode="found")

        # Fuzzy name match — accept if overlap > 0.75
        name_hits = pd.search_persons(args.name)
        for h in name_hits:
            score = fuzzy_match(args.name, h.get("name", ""))
            if score > 0.75:
                success(f"person_id={h['id']} (found by name)", id=h["id"], mode="found")

        # No match — create
        body: dict = {"name": args.name}
        if args.email:
            body["email"] = [{"value": args.email, "primary": True}]
        if args.phone:
            body["phone"] = [{"value": args.phone, "primary": True}]
        if args.org_id:
            body["org_id"] = args.org_id
        resp = pd.post("/persons", body)
        person_id = resp["data"]["id"]
        success(f"person_id={person_id} (created)", id=person_id, mode="created")
    except PDError as e:
        error(str(e))


if __name__ == "__main__":
    main()
